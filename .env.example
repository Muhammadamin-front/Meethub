# =============================================================================
# MeetHub — environment variables
# Copy this file to `.env` and fill in the values. Never commit `.env`.
# NEXT_PUBLIC_* values are exposed to the browser; everything else is server-only.
# =============================================================================

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
# Public base URL of the app (used for emails, webhooks, absolute links).
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# -----------------------------------------------------------------------------
# Database — PostgreSQL (Neon or Supabase) + Prisma   [Phase 1]
# -----------------------------------------------------------------------------
# Pooled connection string used by the app at runtime.
DATABASE_URL="postgresql://user:password@host:5432/meetup?sslmode=require"
# Direct (non-pooled) connection used by Prisma Migrate. With Neon this is the
# unpooled URL; with Supabase use the direct connection on port 5432.
DIRECT_URL="postgresql://user:password@host:5432/meetup?sslmode=require"

# -----------------------------------------------------------------------------
# Auth — Clerk   [Phase 1]
# Enable sign-in methods in the Clerk Dashboard (not in code):
#   - Social: Google, GitHub, Apple = ON
#   - Phone / SMS OTP: OFF (the prebuilt <SignIn/> mirrors these settings)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_xxx"
CLERK_SECRET_KEY="sk_test_xxx"
# Signing secret for the Clerk -> DB user-sync webhook (Clerk Dashboard > Webhooks).
CLERK_WEBHOOK_SIGNING_SECRET="whsec_xxx"
# Routing for Clerk's hosted/mounted auth pages.
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL="/"
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL="/"

# -----------------------------------------------------------------------------
# Realtime — Pusher Channels (private + presence)   [Phase 5 / 7]
# -----------------------------------------------------------------------------
PUSHER_APP_ID="xxxxxx"
PUSHER_SECRET="xxxxxxxxxxxxxxxx"
NEXT_PUBLIC_PUSHER_KEY="xxxxxxxxxxxxxxxx"
NEXT_PUBLIC_PUSHER_CLUSTER="eu"

# -----------------------------------------------------------------------------
# Media — Vercel Blob (images + video)
# -----------------------------------------------------------------------------
# Create a Blob store in the Vercel dashboard (Storage -> Blob) and connect it
# to this project. Vercel then auto-injects BLOB_READ_WRITE_TOKEN into every
# environment — you don't set it by hand (only paste it here for local dev).
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxxxxxxx"
# Flip to "true" once the Blob store is connected to show the upload buttons.
NEXT_PUBLIC_UPLOADS_ENABLED="false"

# -----------------------------------------------------------------------------
# Email — Resend   [Phase 7]
# -----------------------------------------------------------------------------
RESEND_API_KEY="re_xxx"
# Verified sender address (must be a domain verified in Resend).
EMAIL_FROM="MeetHub <noreply@yourdomain.com>"

# -----------------------------------------------------------------------------
# Scheduled jobs — Vercel Cron   [Phase 4]
# -----------------------------------------------------------------------------
# Shared secret; cron route handlers verify the `Authorization: Bearer` header.
CRON_SECRET="generate-a-long-random-string"

# -----------------------------------------------------------------------------
# Admin seeding   [Phase 1]
# -----------------------------------------------------------------------------
# Email of the user to promote to ADMIN when running the seed script.
SEED_ADMIN_EMAIL="you@example.com"
