// MeetUp data model. See README for the domain overview.
// Prisma 7 "prisma-client" generator -> client is generated into
// src/generated/prisma (git-ignored; created by `npm run db:generate`).

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

// Prisma 7: no connection URLs here. Migrate URL is set in prisma.config.ts;
// the runtime client connects via a driver adapter (see src/server/db.ts).
datasource db {
  provider = "postgresql"
}

// ----------------------------------------------------------------------------
// Enums
// ----------------------------------------------------------------------------

enum UserRole {
  USER
  ORGANIZATION
  ADMIN
}

enum OrgStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum EventStatus {
  DRAFT
  PUBLISHED
  CANCELLED
  FINISHED
}

// Visual style for the event card (chosen by the organizer at create time).
enum EventTheme {
  LIGHT_MINIMAL
  DARK_MODERN
  GRADIENT
  NEO_BRUTAL
  GLASS
}

enum RegistrationStatus {
  JOINED
  ATTENDED
  NO_SHOW
}

enum MessageType {
  TEXT
  IMAGE
  VIDEO
}

enum MediaType {
  IMAGE
  VIDEO
}

enum NotificationType {
  EVENT_REMINDER
  NEW_MESSAGE
  ATTENDANCE_MARKED
  REPUTATION_CHANGE
  BLOCKED
  ORG_APPROVED
  ORG_REJECTED
  EVENT_JOINED
  FRIEND_REQUEST
  FRIEND_ACCEPTED
}

enum FriendStatus {
  PENDING
  ACCEPTED
}

// ----------------------------------------------------------------------------
// Models
// ----------------------------------------------------------------------------

model User {
  id           String    @id @default(cuid())
  clerkId      String    @unique
  name         String
  // App-specific profile fields the user fills in after sign-up (Clerk owns
  // name/email/photo). Used for display + the "complete your profile" prompt.
  nickname     String?
  city         String?
  email        String?   @unique
  phone        String?   @unique
  imageUrl     String?
  role         UserRole  @default(USER)
  reputation   Int       @default(100)
  isBlocked    Boolean   @default(false)
  blockedUntil DateTime?
  blockReason  String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // A user may own at most one organization.
  organization  Organization?
  registrations Registration[]
  messages      Message[]
  media         EventMedia[]
  notifications Notification[]
  reviews       Review[]

  // Social graph + direct messages.
  friendRequestsSent     Friendship[]    @relation("FriendRequester")
  friendRequestsReceived Friendship[]    @relation("FriendAddressee")
  conversationsA         Conversation[]  @relation("ConvUserA")
  conversationsB         Conversation[]  @relation("ConvUserB")
  directMessages         DirectMessage[] @relation("DMSender")

  @@index([role])
}

model Organization {
  id          String    @id @default(cuid())
  name        String
  description String?
  logoUrl     String?
  status      OrgStatus @default(PENDING)
  ownerUserId String    @unique
  owner       User      @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  events      Event[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status])
}

model Event {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  title          String
  description    String
  coverUrl       String?
  location       String
  // Structured city (from the fixed UZ list) so the events filter can match
  // exactly — the free-text `location` address is unreliable to filter on.
  city           String?
  // Optional map coordinates (picked from the Leaflet/OpenStreetMap picker).
  latitude       Float?
  longitude      Float?
  startsAt       DateTime
  endsAt         DateTime
  capacity       Int
  category       String
  theme          EventTheme   @default(LIGHT_MINIMAL)
  status         EventStatus  @default(DRAFT)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  registrations Registration[]
  messages      Message[]
  media         EventMedia[]
  reviews       Review[]

  @@index([status, startsAt])
  @@index([organizationId])
  @@index([city])
}

model Registration {
  id       String             @id @default(cuid())
  eventId  String
  event    Event              @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId   String
  user     User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  status   RegistrationStatus @default(JOINED)
  joinedAt DateTime           @default(now())
  markedAt DateTime?

  @@unique([eventId, userId])
  // Drives the trailing-30-day no-show query (Phase 4 auto-block cron).
  @@index([userId, status, joinedAt])
  @@index([eventId, status])
}

model Message {
  id        String      @id @default(cuid())
  eventId   String
  event     Event       @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  content   String?
  mediaUrl  String?
  mediaType MessageType @default(TEXT)
  createdAt DateTime    @default(now())

  @@index([eventId, createdAt])
}

model EventMedia {
  id        String    @id @default(cuid())
  eventId   String
  event     Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  url       String
  type      MediaType
  createdAt DateTime  @default(now())

  @@index([eventId, createdAt])
}

model Review {
  id        String   @id @default(cuid())
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  rating    Int // 1..5
  comment   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // One review per user per event (editable via upsert).
  @@unique([eventId, userId])
  @@index([eventId, createdAt])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  body      String
  data      Json?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  @@index([userId, isRead, createdAt])
}

// A friend request / accepted friendship between two users.
model Friendship {
  id          String       @id @default(cuid())
  requesterId String
  requester   User         @relation("FriendRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  addresseeId String
  addressee   User         @relation("FriendAddressee", fields: [addresseeId], references: [id], onDelete: Cascade)
  status      FriendStatus @default(PENDING)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@unique([requesterId, addresseeId])
  @@index([addresseeId, status])
  @@index([requesterId, status])
}

// A 1:1 direct-message conversation. `userAId` is always the lexicographically
// smaller user id so each pair maps to exactly one row.
model Conversation {
  id            String          @id @default(cuid())
  userAId       String
  userA         User            @relation("ConvUserA", fields: [userAId], references: [id], onDelete: Cascade)
  userBId       String
  userB         User            @relation("ConvUserB", fields: [userBId], references: [id], onDelete: Cascade)
  messages      DirectMessage[]
  lastMessageAt DateTime        @default(now())
  createdAt     DateTime        @default(now())

  @@unique([userAId, userBId])
  @@index([userAId, lastMessageAt])
  @@index([userBId, lastMessageAt])
}

model DirectMessage {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User         @relation("DMSender", fields: [senderId], references: [id], onDelete: Cascade)
  content        String
  readAt         DateTime?
  createdAt      DateTime     @default(now())

  @@index([conversationId, createdAt])
}
